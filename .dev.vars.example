# Cloudflare Workers — local dev secrets template.
#
# Copy to `.dev.vars` (git-ignored) and fill in real values to run
# `npm run cf:preview` locally. Production secrets are set via
# `wrangler secret put NAME` and stored in Cloudflare's encrypted vault.
#
# Mirrors .env.local — same keys, same values.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
DATABASE_URL=
DIRECT_URL=
NEXT_PUBLIC_SITE_URL=http://localhost:8787
