generator client {
  provider      = "prisma-client"
  output        = "../generated/prisma"
  // Use the size-optimized WASM query compiler instead of the default "fast"
  // build. Halves the compiler payload (~4.8 MB -> ~2.4 MB) so the worker
  // fits Cloudflare's size limit; the runtime cost is a marginally slower
  // query-compile step, negligible for this app's query volume.
  compilerBuild = "small"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  instructor
  participant
  judge
}

/// Status of a team's project in the gallery after the workshop ends.
enum ProjectStatus {
  active     // team is still iterating
  archived   // hidden from the gallery (admin only — used rarely)
  shipped    // team has shipped a "v2 / improved / used in real life" marker
}

/// Templated post types for the personal build blog (Feature 2 in the spec).
enum BlogPostType {
  build_update
  experiment
  learning
  shipped
  question
}

/// Photo-wall reaction types. Kid-friendly emoji set:
///   clap  👏 — "great work"
///   love  ❤️ — "love this"
///   idea  💡 — "interesting idea"
/// A user can hold at most one of each type per post (toggle).
enum ReactionType {
  clap
  love
  idea
}

model User {
  id        String   @id @db.Uuid
  email     String   @unique
  name      String?
  role      Role     @default(participant)
  avatarUrl String?
  createdAt DateTime @default(now())

  // Alumni / Builders Platform fields (per spec Feature 7).
  /// Public-friendly slug used in /builders/<handle>. Lowercase, [a-z0-9-].
  /// Null until the alumni claims one in settings.
  handle           String?  @unique
  /// 200-char bio shown on the profile card.
  bio              String?
  /// "15-17" | "18-20" | "20+" — coarse age band for safeguarding signals.
  ageBand          String?
  /// Date of birth — optional. When set during bulk add, used to seed the
  /// person's auto-generated starter password (DDMM portion).
  dob              DateTime?
  /// One-line current focus, editable inline ("Building now: ...").
  buildingNow      String?
  /// When true, the profile is reachable by non-authenticated visitors at
  /// /builders/<handle>. Default false (alumni-only).
  profilePublic    Boolean  @default(false)
  /// When true, surfaces in the Mentor directory once Mentor badge earned.
  mentorAvailable  Boolean  @default(false)
  /// Cohort this alumni belonged to. Optional because pre-cohort users exist.
  cohortId         String?
  cohort           Cohort?  @relation("CohortMembers", fields: [cohortId], references: [id], onDelete: SetNull)

  progress         Progress[]
  savedProjects    SavedProject[]
  teamMembership   TeamMember?
  lookingForTeam   LookingForTeam?
  scoresGiven      Score[]
  wallPosts        WallPost[]
  moderatedPosts   WallPost[] @relation("ModeratedBy")
  reactions        Reaction[]
  comments         Comment[]

  // Alumni platform relations
  earnedBadges     EarnedBadge[]
  awardedBadges    EarnedBadge[] @relation("AwardedBy")
  blogPosts        BlogPost[]
  blogComments     BlogComment[]
  buildLogEntries  BuildLogEntry[]
  cohortPosts      CohortPost[]
  sessionRegistrations  SessionRegistration[]
  showAndTellAppearances ShowAndTellPresenter[]
  featuredBuilderMonths  FeaturedBuilder[]
  /// Many-to-many workshop memberships. Use this for "all my workshops";
  /// `cohortId` above stays around as the user's current/primary workshop.
  workshops        UserCohort[]
  /// Team chat messages this user has posted.
  teamMessages     TeamMessage[]
  /// Reactions + comments on other teams' projects (gallery detail).
  projectReactions ProjectReaction[]
  projectComments  ProjectComment[]
  /// Direct messages — paired side of every conversation this user is in.
  conversationsA   Conversation[] @relation("ConversationUserA")
  conversationsB   Conversation[] @relation("ConversationUserB")
  /// Direct messages this user authored.
  directMessages   DirectMessage[]

  @@index([handle])
  @@index([cohortId])
  @@map("User")
}

/// A cohort run of the Karya Sanga workshop. Per the spec: "Cohort 4 · Aug 2026".
/// Members are linked via User.cohortId.
model Cohort {
  id          String   @id @default(cuid())
  /// Display name shown on profiles and the cohort space header.
  name        String   @unique
  /// Coarse start date — used in sorting and in "Cohort N · Month YYYY" labels.
  startedOn   DateTime?
  endedOn     DateTime?
  /// Markdown description shown at the top of the cohort space.
  description String?
  /// When true, the cohort is the "current" one. UI may surface this.
  current     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// Single-FK members — kept for backwards compatibility. Newer code reads
  /// `UserCohort` (the join table) so a user can belong to multiple workshops.
  members  User[]       @relation("CohortMembers")
  posts    CohortPost[]
  projects Team[]
  /// Modules from the global library attached to this workshop. The library
  /// (Module + Lesson) is reusable across workshops; this join chooses which
  /// modules each workshop surfaces and in what order.
  attachedModules WorkshopModule[]
  /// Memberships — a user can be in many workshops via this join.
  memberships UserCohort[]
  /// Workshop-scoped badges (optional cohortId on Badge).
  badges      Badge[]
  /// Optional per-workshop hackathon config override (deadline, team size,
  /// leaderboard visibility). Falls back to the singleton default row when
  /// absent.
  hackathonConfig HackathonConfig?

  @@index([current])
  @@index([startedOn])
  @@map("Cohort")
}

/// Join table: which users belong to which workshops. Replaces the single-FK
/// `User.cohortId` design for users who attend more than one workshop. The
/// old FK stays around so existing queries don't break; new code prefers
/// this join. `User.cohortId` is treated as the user's "primary" workshop.
model UserCohort {
  id        String   @id @default(cuid())
  userId    String   @db.Uuid
  cohortId  String
  /// When the user joined this workshop.
  joinedAt  DateTime @default(now())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  cohort Cohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  @@unique([userId, cohortId])
  @@index([userId])
  @@index([cohortId])
  @@map("UserCohort")
}

/// A chronological text post in a cohort space (Feature 8).
model CohortPost {
  id        String   @id @default(cuid())
  cohortId  String
  authorId  String   @db.Uuid
  body      String   @db.Text
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cohort Cohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([cohortId, pinned, createdAt])
  @@map("CohortPost")
}

/// One chronological build-log entry on a team's project page (Feature 1).
/// Multiple per team; lives alongside the Team.buildLog free-form field.
model BuildLogEntry {
  id        String   @id @default(cuid())
  teamId    String
  authorId  String   @db.Uuid
  body      String   @db.Text
  /// Optional Wokwi URL referenced in this entry.
  wokwiUrl  String?
  /// Optional image path in lesson-slides or a future build-log bucket.
  imagePath String?
  createdAt DateTime @default(now())

  team   Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([teamId, createdAt])
  @@map("BuildLogEntry")
}

/// Catalog of all badges (workshop + post-workshop). Seeded once.
/// Earned instances live in EarnedBadge.
model Badge {
  id          String   @id @default(cuid())
  /// Stable slug used in code (e.g. "hallucination-hunter").
  slug        String   @unique
  name        String
  /// Short user-facing description shown on hover.
  description String
  /// How the badge is earned, shown on the "How to earn" page.
  criteria    String
  /// Material Symbols icon name OR an emoji.
  icon        String
  /// Tonal slot: "primary" | "secondary" | "tertiary" — for sticker styling.
  tone        String   @default("primary")
  /// "workshop" or "platform" — drives grouping on the profile.
  category    String   @default("workshop")
  /// Whether the badge can self-award (automatic) or needs admin action.
  selfAward   Boolean  @default(false)
  order       Int      @default(0)
  /// Optional: scope this badge to one workshop. Null = global. When set,
  /// only that workshop's members can earn it and admins of that workshop
  /// can award it.
  cohortId    String?
  cohort      Cohort?  @relation(fields: [cohortId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  earned EarnedBadge[]

  @@index([category, order])
  @@index([cohortId])
  @@map("Badge")
}

/// Many-to-many: a user has earned a badge at a point in time.
model EarnedBadge {
  id         String   @id @default(cuid())
  userId     String   @db.Uuid
  badgeId    String
  /// Optional note (e.g. "Awarded after shipping a Plant Companion v2").
  note       String?
  /// Who awarded it. Null for system-issued (selfAward badges).
  awardedById String? @db.Uuid
  earnedAt   DateTime @default(now())

  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge   Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  awarder User? @relation("AwardedBy", fields: [awardedById], references: [id], onDelete: SetNull)

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
  @@map("EarnedBadge")
}

/// Personal alumni blog post (Feature 2 — UI lands in v1.1; model now to avoid re-migration).
model BlogPost {
  id           String       @id @default(cuid())
  authorId     String       @db.Uuid
  type         BlogPostType @default(build_update)
  title        String
  body         String       @db.Text
  /// Optional project tag — links the post to a Team's gallery entry.
  taggedTeamId String?
  /// Visibility: false = alumni-only (default), true = publicly readable.
  isPublic     Boolean      @default(false)
  /// Soft delete flag — keeps thread context if admin removes.
  removed      Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  author      User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  taggedTeam  Team?         @relation(fields: [taggedTeamId], references: [id], onDelete: SetNull)
  comments    BlogComment[]

  @@index([authorId, createdAt])
  @@index([type])
  @@index([isPublic, createdAt])
  @@map("BlogPost")
}

model BlogComment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String   @db.Uuid
  body      String   @db.Text
  removed   Boolean  @default(false)
  createdAt DateTime @default(now())

  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@map("BlogComment")
}

/// Take It Further session (Feature 4 — UI in v1.2; model now).
model TakeItFurtherSession {
  id           String   @id @default(cuid())
  title        String
  description  String?  @db.Text
  startsAt     DateTime
  durationMin  Int      @default(60)
  capacity     Int      @default(20)
  joinUrl      String?
  recordingUrl String?
  deckUrl      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  registrations SessionRegistration[]

  @@index([startsAt])
  @@map("TakeItFurtherSession")
}

model SessionRegistration {
  id         String   @id @default(cuid())
  sessionId  String
  userId     String   @db.Uuid
  registeredAt DateTime @default(now())

  session TakeItFurtherSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@map("SessionRegistration")
}

/// Quarterly Show & Tell event (Feature 5 — UI in v2).
model ShowAndTellEvent {
  id           String   @id @default(cuid())
  title        String
  scheduledAt  DateTime
  description  String?  @db.Text
  recordingUrl String?
  createdAt    DateTime @default(now())

  presenters ShowAndTellPresenter[]

  @@map("ShowAndTellEvent")
}

model ShowAndTellPresenter {
  id        String   @id @default(cuid())
  eventId   String
  userId    String   @db.Uuid
  /// Optional team/project they're presenting.
  teamId    String?
  /// Slot order in the agenda.
  slotOrder Int      @default(0)
  createdAt DateTime @default(now())

  event ShowAndTellEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  team  Team?            @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@unique([eventId, userId])
  @@map("ShowAndTellPresenter")
}

/// Featured Builder of the Month (Feature 6 — UI in v1.1).
/// One per month, enforced by a unique on (yearMonth).
model FeaturedBuilder {
  id          String   @id @default(cuid())
  userId      String   @db.Uuid
  /// "YYYY-MM" — one builder per calendar month, enforced by @@unique.
  yearMonth   String
  articleUrl  String?
  reelUrl     String?
  blurb       String?  @db.Text
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([yearMonth])
  @@index([userId])
  @@map("FeaturedBuilder")
}

/// Singleton row that holds workshop-wide hackathon config + photo-wall config.
/// Keyed by id="default" so instructors can read/update without enumerating.
/// (Will likely be renamed to AppConfig once it grows; the name is incidental.)
model HackathonConfig {
  id              String   @id @default("default")
  /// Optional per-workshop override. When set, lookups for that workshop
  /// prefer this row over the global `id = "default"` singleton.
  cohortId        String?  @unique
  cohort          Cohort?  @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  /// Max members per team (default 5 per the brief).
  maxTeamSize     Int      @default(5)
  /// Hackathon submission deadline — used to lock edits. Null = open-ended.
  submitBy        DateTime?
  /// Toggle to make the leaderboard public after judging closes.
  leaderboardPublic Boolean @default(false)
  /// Photo wall: when true, instructor must approve before a post is visible.
  wallRequireApproval Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("HackathonConfig")
}

model Team {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?

  /// Workspace fields (per-team scratch). Lockable later via submission flow.
  projectTitle       String?
  projectDescription String?
  repoUrl            String?
  buildLog           String?  @db.Text

  /// When true, solo participants can see this team in "browse teams" UI.
  lookingForMembers Boolean @default(true)

  // Project Gallery fields (alumni platform — Feature 1).
  /// Which cohort this project came from. Used for sorting + filter.
  cohortId   String?
  cohort     Cohort?       @relation(fields: [cohortId], references: [id], onDelete: SetNull)
  /// Lifecycle for the gallery view.
  status     ProjectStatus @default(active)
  /// Long-form "what problem it solves" — students' own words, markdown.
  story      String?       @db.Text
  /// Architecture description / diagram source, markdown.
  architecture String?     @db.Text
  /// Storage path to hero image (lesson-slides bucket reused for now).
  heroImagePath String?
  /// Topical tags ("sensor: HC-SR04", "domain: plants", "ai: openai").
  tags       String[]      @default([])
  /// Set by admin to surface on the gallery's "Featured" slot.
  featured   Boolean       @default(false)
  /// Month the team was featured (YYYY-MM); kept for analytics.
  featuredAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members    TeamMember[]
  wokwiLinks TeamWokwiLink[]
  submission Submission?
  buildLogEntries BuildLogEntry[]
  taggedBlogPosts BlogPost[]
  showAndTellAppearances ShowAndTellPresenter[]
  /// Team-only group chat (per spec: "group discussion within the team").
  messages   TeamMessage[]
  /// Public reactions on the gallery detail page (👏 ❤️ 💡).
  reactions  ProjectReaction[]
  /// Public threaded comments on the gallery detail page.
  comments   ProjectComment[]
  /// Embed-able media URLs (YouTube, Vimeo, SoundCloud, etc.) shown on the
  /// gallery detail. Authoring is gated to team members + mods.
  mediaUrls  String[] @default([])

  @@index([lookingForMembers])
  @@index([cohortId, status])
  @@index([featured])
  @@map("Team")
}

/// Reaction on a project (gallery item). Mirrors WallPost's `Reaction` so the
/// emoji set + uniqueness rule stay consistent.
model ProjectReaction {
  id        String       @id @default(cuid())
  teamId    String
  userId    String       @db.Uuid
  type      ReactionType
  createdAt DateTime     @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId, type])
  @@index([teamId])
  @@map("ProjectReaction")
}

/// Comment on a project (gallery item).
model ProjectComment {
  id        String   @id @default(cuid())
  teamId    String
  authorId  String   @db.Uuid
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team   Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([teamId, createdAt])
  @@map("ProjectComment")
}

/// Team-scoped chat. Only team members + mods can read or post. Used inside
/// the hackathon team workspace for coordinating builds, sharing links, etc.
model TeamMessage {
  id        String   @id @default(cuid())
  teamId    String
  authorId  String   @db.Uuid
  body      String   @db.Text
  createdAt DateTime @default(now())

  team   Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([teamId, createdAt])
  @@map("TeamMessage")
}

/// Frozen team submission for judging. One per team (enforced by unique).
/// Created via `submitProject` action — gated by HackathonConfig.submitBy.
/// `locked=true` means members cannot edit; admin can flip to allow edits.
model Submission {
  id              String   @id @default(cuid())
  teamId          String   @unique
  title           String
  description     String   @db.Text
  demoVideoUrl    String?
  wokwiProjectUrl String?
  repoUrl         String?
  submittedAt     DateTime @default(now())
  submittedById   String   @db.Uuid
  locked          Boolean  @default(true)
  updatedAt       DateTime @updatedAt

  team   Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  scores Score[]

  @@index([submittedAt])
  @@map("Submission")
}

/// One row per judge per submission. Scores are 1-10 across four criteria
/// from the brief: innovation, technical execution, AI use, presentation.
model Score {
  id           String   @id @default(cuid())
  submissionId String
  judgeId      String   @db.Uuid
  innovation   Int
  technical    Int
  aiUse        Int
  presentation Int
  comment      String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  judge      User       @relation(fields: [judgeId], references: [id], onDelete: Cascade)

  @@unique([submissionId, judgeId])
  @@index([submissionId])
  @@map("Score")
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  /// One team per user across the workshop (enforced by unique on userId).
  userId    String   @db.Uuid @unique
  isCaptain Boolean  @default(false)
  joinedAt  DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@map("TeamMember")
}

/// A Wokwi project link the team has bookmarked for their build.
/// Lives separate from per-user SavedProject so adding a link doesn't require
/// a user to "save" it first.
model TeamWokwiLink {
  id              String   @id @default(cuid())
  teamId          String
  label           String
  wokwiProjectUrl String
  addedById       String   @db.Uuid
  createdAt       DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@map("TeamWokwiLink")
}

/// Free-form "I'm looking for a team" post for solo participants.
/// One per user (upserted) so the board stays clean.
model LookingForTeam {
  id        String   @id @default(cuid())
  userId    String   @db.Uuid @unique
  skills    String
  interests String?
  contact   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("LookingForTeam")
}

/// Photo wall post — an image + caption, visible only to logged-in users.
///
/// Images live in Supabase Storage bucket `wall-images` under
/// `<authorId>/<random>.<ext>`. The bucket is PRIVATE — only signed URLs work.
/// Server-side code reads `imagePath` and mints a short-lived signed URL.
///
/// Posts default to `approved=false` when wallRequireApproval is on. When the
/// flag is off, new posts are auto-approved at insert time.
/// Kind of wall post:
///   photo  — image required, optional caption (the original)
///   update — short text-only post (no image), like a status
///   blog   — long-form post with title + body, optional cover image
enum WallPostType {
  photo
  update
  blog
}

model WallPost {
  id           String        @id @default(cuid())
  authorId     String        @db.Uuid
  /// What kind of post this is. Drives composer fields + feed rendering.
  kind         WallPostType  @default(photo)
  /// Storage path for the image. Required for `photo`; optional cover for
  /// `blog`; null for `update`.
  imagePath    String?
  /// Used as the photo caption, or kept on updates/blogs for compatibility.
  caption      String?       @db.Text
  /// Long-form body (markdown). Used by `update` and `blog`.
  body         String?       @db.Text
  /// Blog title. Required for `blog`, ignored otherwise.
  title        String?
  tags         String[]      @default([])
  /// Embed-able extras (YouTube, Vimeo, SoundCloud, image, PDF, etc.).
  /// Rendered inline by the MediaEmbed component.
  mediaUrls    String[]      @default([])

  approved     Boolean  @default(false)
  approvedAt   DateTime?
  approvedById String?  @db.Uuid

  /// If rejected by a moderator, store the reason for the author to see.
  rejected     Boolean  @default(false)
  rejectionReason String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  moderator User?      @relation("ModeratedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  reactions Reaction[]
  comments  Comment[]

  @@index([approved, createdAt])
  @@index([authorId])
  @@map("WallPost")
}

/// One reaction per (user, post, type). Toggling deletes; reacting inserts.
model Reaction {
  id        String       @id @default(cuid())
  postId    String
  userId    String       @db.Uuid
  type      ReactionType
  createdAt DateTime     @default(now())

  post WallPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, type])
  @@index([postId])
  @@map("Reaction")
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String   @db.Uuid
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post   WallPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@map("Comment")
}

/// Instructor-curated Wokwi starter project. Kids see these on `/simulator`
/// as "open this starter" cards. Clicking opens the Wokwi URL in a new tab
/// (consistent with the no-iframe decision); kids fork it via Wokwi's
/// native "Save a Copy" button, then paste the new URL into SavedProject.
///
/// This is the closest we can get to "automatic project creation" — Wokwi
/// has no public API to create a project with predefined code/diagram, so
/// curated starters + one-click board launchers are the realistic UX.
model WokwiStarter {
  id              String   @id @default(cuid())
  label           String   @unique
  description     String?
  /// Board kind for the icon/badge — values like "esp32", "esp32-s3",
  /// "arduino-uno". Free-form for now; the UI maps a known set to icons.
  board           String   @default("esp32")
  /// Concept tag for grouping: "blink", "sensor", "actuator", "ai", etc.
  category        String?
  wokwiProjectUrl String
  order           Int      @default(0)
  published       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([published, order])
  @@map("WokwiStarter")
}

model SavedProject {
  id              String   @id @default(cuid())
  ownerId         String   @db.Uuid
  name            String
  /// Validated to be a Wokwi project URL before insert.
  wokwiProjectUrl String
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@map("SavedProject")
}

model Module {
  id          String   @id @default(cuid())
  title       String
  description String?
  /// Default order in the library (not per-workshop — that lives on
  /// WorkshopModule.order).
  order       Int      @default(0)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lessons Lesson[]
  /// Workshops this module has been attached to. A module is a library
  /// asset — many workshops can reuse the same module.
  attachedToWorkshops WorkshopModule[]

  @@index([order])
  @@map("Module")
}

/// Join table: which library modules are attached to which workshops.
/// Lets us reuse a module across multiple workshops and reorder per workshop
/// without duplicating lesson content. Per-workshop ordering is on `order`.
model WorkshopModule {
  id        String   @id @default(cuid())
  cohortId  String
  moduleId  String
  /// Per-workshop display order. Module.order is only a library-level default.
  order     Int      @default(0)
  createdAt DateTime @default(now())

  cohort Cohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([cohortId, moduleId])
  @@index([cohortId, order])
  @@map("WorkshopModule")
}

model Lesson {
  id              String   @id @default(cuid())
  moduleId        String
  title           String
  summary         String?
  /// Lesson body as markdown. Rendered server-side via react-markdown.
  /// To author slides, separate sections with `---` (a markdown horizontal
  /// rule). The presenter view at /lessons/[id]/present splits on these
  /// and shows one slide at a time. The reader view renders them as one
  /// continuous document.
  body            String   @default("")
  /// Optional Wokwi project URL. The viewer opens this in a new tab (no iframe).
  wokwiProjectUrl String?
  /// Optional external slides URL (Google Slides "publish to web", PDF link,
  /// etc.) — opens in a new tab. Use this when you've already got a deck
  /// you want to attach rather than rewriting it as markdown slides.
  slidesUrl       String?
  /// Optional file uploaded by the instructor (PDF / PPT / PPTX). Lives in
  /// the private Supabase Storage bucket `lesson-slides` under
  /// `<uploaderId>/<random>.<ext>`. PDFs render inline via signed URL;
  /// PPT/PPTX need the Office Online viewer (requires a public-reachable
  /// host — i.e. the deployed site, not localhost).
  slideFilePath   String?
  slideFileType   String?   // mime type: application/pdf | application/vnd.ms-powerpoint | application/vnd.openxmlformats-officedocument.presentationml.presentation
  slideFileName   String?   // original filename, for the download UI
  difficulty      String?  // "Easy" | "Medium" | "Hard" — kid-friendly tag
  order           Int      @default(0)
  published       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  module   Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress Progress[]

  @@index([moduleId, order])
  @@map("Lesson")
}

model Progress {
  id          String    @id @default(cuid())
  userId      String    @db.Uuid
  lessonId    String
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@map("Progress")
}

/// Direct-message conversation between two users.
///
/// `userAId` and `userBId` are sorted by UUID (A < B lexicographically) so
/// every pair has exactly one Conversation row regardless of who started it.
/// Lookups: "is there a thread between X and Y?" → `findUnique` on the
/// unique pair.
model Conversation {
  id            String   @id @default(cuid())
  userAId       String   @db.Uuid
  userBId       String   @db.Uuid
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())

  userA    User            @relation("ConversationUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB    User            @relation("ConversationUserB", fields: [userBId], references: [id], onDelete: Cascade)
  messages DirectMessage[]

  @@unique([userAId, userBId])
  @@index([userAId, lastMessageAt])
  @@index([userBId, lastMessageAt])
  @@map("Conversation")
}

/// One direct message within a conversation. `readAt` is set when the
/// recipient (anyone whose id != authorId) opens the thread.
model DirectMessage {
  id             String   @id @default(cuid())
  conversationId String
  authorId       String   @db.Uuid
  body           String   @db.Text
  createdAt      DateTime @default(now())
  readAt         DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author       User         @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("DirectMessage")
}
