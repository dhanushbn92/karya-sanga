# Supabase project — see Project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Supabase rolled out new key names in late 2025. Use whichever one your
# dashboard shows you. Either env var works; the code prefers the new one.
#
# New format (preferred): "API keys" section, "Publishable" row
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx
# OR legacy format: "Project API keys", "anon public" row
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-only. NEVER prefix with NEXT_PUBLIC_. Used for privileged jobs only.
# New format: "Secret" key. Legacy format: "service_role" key.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxx
# Or legacy:
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Prisma → Supabase Postgres (Project settings → Database → Connection string)
# Pooled connection (port 6543) for the runtime app:
DATABASE_URL="postgresql://postgres.YOUR-PROJECT-REF:YOUR-DB-PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) used by `prisma migrate` only:
DIRECT_URL="postgresql://postgres.YOUR-PROJECT-REF:YOUR-DB-PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Public site URL (used by Supabase to build OAuth redirect URLs):
NEXT_PUBLIC_SITE_URL=http://localhost:3000
